{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "outDir": "dist",
        "rootDir": ".",
        "declaration": true,
        "sourceMap": true,
        "strict": true,
        "resolveJsonModule": true,
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "baseUrl": ".",
        "paths": {
            "@openaddresses/cfn-config": ["types/cfn-config.d.ts"]
        },
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "noEmitOnError": true,
        "types": ["node", "vitest/globals"]
    },
    "include": [
        "cli.ts",
        "lib/**/*.ts",
        "test/**/*.ts",
        "types/**/*.d.ts"
    ],
    "exclude": ["dist", "docs", "node_modules"]
}